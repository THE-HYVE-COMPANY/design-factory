{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "SPIKE capability — core window + permission to spawn the df-daemon sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/df-daemon", "sidecar": true }]
    }
  ]
}
