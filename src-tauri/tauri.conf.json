{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Design Factory",
  "version": "0.1.0",
  "identifier": "company.hyve.design-factory",
  "build": {
    "beforeBuildCommand": "npm run build && node scripts/build-daemon-bin.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/df-daemon"],
    "longDescription": "Design Factory — local-first, multi-provider, model-agnostic design tool. SPIKE config (not production).",
    "shortDescription": "Design Factory"
  },
  "plugins": {}
}
